# Appium Configuration
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# Device Configuration
DEVICE_UDID=your_device_udid_here

# TEMM App Credentials
TEMM_USER=your_username_here
TEMM_PASS=your_password_here

# Search Parameters (Port sin DN Tránsito)
# DN es obligatorio, RFC y Request ID son opcionales
SEARCH_DN=
SEARCH_RFC=
SEARCH_REQUEST_ID=

# ICC (opcional) - Para bloqueo ICC
ICC=

# Sección Línea - FVC
# Índice de fecha a seleccionar (1 = primera fecha disponible, 5 = quinta fecha, etc.)
# El sistema muestra diferentes fechas según la hora (antes/después de las 5 PM)
# El bot seleccionará automáticamente la fecha en la posición indicada
FVC_INDICE=1
# NIP para la sección Línea
LINEA_NIP=

# Sección 2: Datos Personales
DATOS_NOMBRE=
DATOS_NOMBRE_SEGUNDO=
DATOS_APELLIDO_PATERNO=
DATOS_APELLIDO_MATERNO=
DATOS_CURP=
DATOS_TELEFONO=
DATOS_TELEFONO_2=
DATOS_GENERO=Masculino
DATOS_EMAIL=
DATOS_FECHA_NACIMIENTO=
