{
  "name": "movistar-worker-agent",
  "version": "1.0.0",
  "description": "Worker agent for Movistar portability bot - Local execution node",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "kiosk": "KIOSK_MODE=true node dist/index.js",
    "register": "ts-node src/scripts/register.ts",
    "test": "ts-node src/test.ts"
  },
  "keywords": [
    "worker",
    "agent",
    "appium",
    "android",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.5",
    "blessed": "^0.1.81",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
