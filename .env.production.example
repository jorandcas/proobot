# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here_change_in_production
POSTGRES_DB=movistar_bot

# Redis
REDIS_PASSWORD=your_redis_password_here_change_in_production

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production_minimum_32_characters
JWT_EXPIRES_IN=24h

# Server
NODE_ENV=production

# Workers Configuration
WORKER_CHECK_INTERVAL=60000      # 1 minuto
WORKER_TIMEOUT=120000            # 2 minutos
CLEAN_INTERVAL=3600000           # 1 hora
MAX_JOB_AGE=604800000            # 7 días
MAX_EVIDENCE_AGE=604800000       # 7 días

# Frontend
VITE_API_URL=https://api.tu-dominio.com

# Domain (for Nginx)
DOMAIN=tu-dominio.com
SSL_EMAIL=admin@tu-dominio.com

# Admin Credentials (First Setup)
ADMIN_EMAIL=admin@tu-dominio.com
ADMIN_PASSWORD=change_this_password_immediately
ADMIN_NAME=Administrador
