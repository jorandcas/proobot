# ==============================================
# CONFIGURACIÓN DE ACCESO MÓVIL Y RED
# ==============================================
#
# Este archivo configura cómo el frontend se conecta al backend.
#
# 🔴 IMPORTANTE: Lee esto antes de configurar
# ==============================================
#
# 1. ACCESO DESDE LA MISMA COMPUTADORA (localhost):
#    VITE_API_URL=http://localhost:3001/api
#
# 2. ACCESO DESDE UN CELULAR O DISPOSITIVO EXTERNO:
#    a) Conecta el celular a la misma red WiFi que tu PC
#    b) Obtén la IP de tu computadora:
#       - Windows: ipconfig (buscar "IPv4 Address")
#       - Linux: ip addr show
#       - Mac: ifconfig
#    c) Cambia localhost por tu IP:
#       VITE_API_URL=http://192.168.1.X:3001/api
#       (reemplaza 192.168.1.X con tu IP real)
#
# 3. CÓMO VERIFICAR QUE FUNCIONA:
#    a) Desde tu PC: http://localhost:3000
#    b) Desde el celular: http://<TU_IP_PC>:3000
#    c) El backend mostrará logs con la IP del cliente
#
# ==============================================

# Configuración por defecto (solo funciona desde la misma PC)
VITE_API_URL=http://localhost:3001/api

# Para acceso desde celular, descomenta y cambia la IP:
# VITE_API_URL=http://192.168.1.100:3001/api
