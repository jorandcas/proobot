# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret
JWT_SECRET=tu_secreto_jwt_aqui_cambialo_en_produccion
JWT_EXPIRES_IN=24h

# Admin Default Credentials (for first setup)
ADMIN_EMAIL=admin@telcel.mx
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# Bot Configuration
BOT_TIMEOUT=300000
BOT_RETRY_ATTEMPTS=3
BOT_RETRY_DELAY=5000

# Database Path
DB_PATH=./src/data/database.json

# ============================================
# NUEVA CONFIGURACIÓN - SISTEMA DE COLAS Y WORKERS
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/movistar_bot"

# Redis (Colas)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Workers
WORKER_CHECK_INTERVAL="60000"      # 1 minuto - Verificación de workers offline
WORKER_TIMEOUT="120000"            # 2 minutos - Tiempo sin heartbeat para considerar offline
CLEAN_INTERVAL="3600000"           # 1 hora - Intervalo de limpieza
MAX_JOB_AGE="604800000"            # 7 días - Edad máxima de trabajos para mantener
MAX_EVIDENCE_AGE="604800000"       # 7 días - Edad máxima de evidencias para mantener

# Evidence Storage
EVIDENCE_PATH="./uploads/evidence"
EVIDENCE_URL_PREFIX="/evidence"

# Worker Monitor
ENABLE_WORKER_MONITOR="true"       # Habilitar monitor de workers
